# 复制为 .env.local 后生效（修改后需要重启 npm run dev）
# 注意：如果你在“别的电脑/手机”访问云服务器的 5173，
# 默认的 http://127.0.0.1:5000 会指向访问者本机，必然 Failed to fetch。

# 后端 HTTP 基地址（Flask）
VITE_API_BASE=http://<your-server-public-ip>:5000

# 可选：dashboard WS 地址；不填则从 VITE_API_BASE 推导为 ws://.../ws/dashboard
# VITE_WS_DASHBOARD_URL=ws://<your-server-public-ip>:5000/ws/dashboard

# Bearer Key（与 Server 端 SLS_API_KEYS 对齐；默认 dev_key）
VITE_API_KEY=dev_key
